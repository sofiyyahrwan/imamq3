body{
font-family: Arial;
background:#f2f2f2;
text-align:center;
}

h1{
margin-top:30px;
}

.card{
background:white;
width:300px;
margin:20px auto;
padding:20px;
border-radius:10px;
box-shadow:0 3px 10px rgba(0,0,0,0.1);
}

button{
padding:10px 20px;
border:none;
background:#2e7d32;
color:white;
border-radius:5px;
cursor:pointer;
}

.rotateBtn{
margin-top:20px;
font-size:16px;
}
